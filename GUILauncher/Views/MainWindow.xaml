<Window x:Class="SBGModLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SBGModLauncher.ViewModels"
        Title="Super Battle Golf - Mod Launcher" 
        Height="700" Width="1000"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <!-- Dark golf-themed color scheme -->
        <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#1A1D23"/>
        <SolidColorBrush x:Key="DarkPanelBrush" Color="#242830"/>
        <SolidColorBrush x:Key="DarkCardBrush" Color="#2C313D"/>
        <SolidColorBrush x:Key="DarkHeaderBrush" Color="#1E2229"/>
        
        <!-- Golf-themed accent colors -->
        <SolidColorBrush x:Key="GolfGreenBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="GolfBlueBrush" Color="#2196F3"/>
        <SolidColorBrush x:Key="GolfOrangeBrush" Color="#FF6B35"/>
        <SolidColorBrush x:Key="GolfGoldBrush" Color="#FFB627"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E63946"/>
        
        <!-- Text colors -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8E9ED"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6B7280"/>
        
        <!-- Modern button style with hover effects -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GolfGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Dark ListView style -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource DarkCardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#3A3F4B"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Dark TabControl style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource DarkPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                BorderThickness="0" CornerRadius="6,6,0,0" Margin="2,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource DarkCardBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#343945"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- CheckBox dark style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        
        <!-- TextBlock dark style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="{StaticResource DarkBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource DarkHeaderBrush}" Padding="20,15" BorderBrush="{StaticResource GolfGreenBrush}" BorderThickness="0,0,0,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="⛳ SUPER BATTLE GOLF" FontSize="24" FontWeight="Bold" Foreground="{StaticResource GolfGreenBrush}"/>
                    <TextBlock Text="Mod Launcher v1.0.0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Game:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GameVersion}" Foreground="{StaticResource GolfGoldBrush}" VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="SemiBold"/>
                    <Button Content="📁 Browse..." Command="{Binding BrowseGamePathCommand}" 
                            Style="{StaticResource PrimaryButton}" Background="{StaticResource GolfBlueBrush}" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource DarkPanelBrush}" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#3A3F4B" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⚡ QUICK ACTIONS" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource GolfGoldBrush}" FontSize="13"/>
                    
                    <Button Content="▶️ Launch with Mods" Command="{Binding LaunchWithModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Background="{StaticResource GolfGreenBrush}"/>
                    
                    <Button Content="🎮 Launch Vanilla" Command="{Binding LaunchVanillaCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Background="#4B5563"/>
                    
                    <Separator Margin="0,10" Background="#3A3F4B"/>
                    
                    <TextBlock Text="🔧 MOD MANAGEMENT" FontWeight="Bold" Margin="0,10,0,15" Foreground="{StaticResource GolfGoldBrush}" FontSize="13"/>
                    
                    <Button Content="🔄 Refresh Mods" Command="{Binding RefreshModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,6" Background="{StaticResource GolfBlueBrush}"/>
                    
                    <Button Content="✅ Enable All" Command="{Binding EnableAllModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,6,0,6" Background="{StaticResource GolfGreenBrush}"/>
                    
                    <Button Content="❌ Disable All" Command="{Binding DisableAllModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,6,0,6" Background="{StaticResource DangerBrush}"/>
                    
                    <Button Content="📁 Open Mods Folder" Command="{Binding OpenModsFolderCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,6,0,0" Background="#6366F1"/>
                    
                    <Separator Margin="0,15,0,10" Background="#3A3F4B"/>
                    
                    <TextBlock Text="🌐 DISCOVER MORE" FontWeight="Bold" Margin="0,5,0,15" Foreground="{StaticResource GolfGoldBrush}" FontSize="13"/>
                    
                    <Button Content="🌐 Browse Mods" Command="{Binding OpenModBrowserCommand}"
                            Style="{StaticResource PrimaryButton}" Background="{StaticResource GolfOrangeBrush}" Margin="0,0,0,0"/>
                    
                    <Separator Margin="0,15,0,10" Background="#3A3F4B"/>
                    
                    <Border Background="{StaticResource DarkCardBrush}" CornerRadius="6" Padding="12" BorderBrush="#4CAF50" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="📊 STATISTICS" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource GolfGreenBrush}"/>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Total Mods: "/>
                                <Run Text="{Binding TotalModsCount}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Enabled: "/>
                                <Run Text="{Binding EnabledModsCount}" FontWeight="Bold" Foreground="{StaticResource GolfGreenBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Mod List -->
            <Border Grid.Column="1" Background="{StaticResource DarkPanelBrush}" CornerRadius="8" Padding="15" BorderBrush="#3A3F4B" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Tabs -->
                    <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <!-- All Mods Tab -->
                        <TabItem Header="All Mods">
                            <ListView ItemsSource="{Binding AllMods}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}" 
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeDisplay}" Width="100"/>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusIndicator}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Maps Tab -->
                        <TabItem Header="🗺️ Maps">
                            <ListView ItemsSource="{Binding Maps}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="250"/>
                                        <GridViewColumn Header="Holes" DisplayMemberBinding="{Binding Meta.Holes}" Width="60"/>
                                        <GridViewColumn Header="Difficulty" DisplayMemberBinding="{Binding Meta.Difficulty}" Width="100"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Game Modes Tab -->
                        <TabItem Header="🎮 Game Modes">
                            <ListView ItemsSource="{Binding GameModes}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Characters Tab -->
                        <TabItem Header="👤 Characters">
                            <ListView ItemsSource="{Binding Characters}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Items Tab -->
                        <TabItem Header="⚔️ Items">
                            <ListView ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Mod Details Panel -->
                    <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                        <StackPanel DataContext="{Binding SelectedMod}">
                            <TextBlock Text="Mod Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,5,0,5"/>
                            <TextBlock Margin="0,5,0,0">
                                <Run Text="Author: "/><Run Text="{Binding Author}" FontWeight="SemiBold"/>
                                <Run Text=" • "/>
                                <Run Text="Version: "/><Run Text="{Binding Version}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource DarkHeaderBrush}" Padding="15,10" BorderBrush="{StaticResource GolfGreenBrush}" BorderThickness="0,2,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource GolfGreenBrush}" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="v1.0.0-beta" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>
