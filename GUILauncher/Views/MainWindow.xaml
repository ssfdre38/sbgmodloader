<Window x:Class="SBGModLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SBGModLauncher.ViewModels"
        Title="Super Battle Golf - Mod Launcher" 
        Height="700" Width="1000"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <!-- Modern color scheme -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2196F3"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFC107"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>
        
        <!-- Button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="🏌️ Super Battle Golf" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Mod Manager &amp; Launcher" FontSize="14" Foreground="#E0E0E0" Margin="0,2,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Game:" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GameVersion}" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="Browse..." Command="{Binding BrowseGamePathCommand}" 
                            Style="{StaticResource PrimaryButton}" Background="#1976D2"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="QUICK ACTIONS" FontWeight="Bold" Margin="5,5,5,15"/>
                    
                    <Button Content="▶️ Launch with Mods" Command="{Binding LaunchWithModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" Background="{StaticResource SuccessBrush}"/>
                    
                    <Button Content="🎮 Launch Vanilla" Command="{Binding LaunchVanillaCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" Background="#757575"/>
                    
                    <Separator Margin="0,10"/>
                    
                    <TextBlock Text="MOD MANAGEMENT" FontWeight="Bold" Margin="5,15,5,15"/>
                    
                    <Button Content="🔄 Refresh Mods" Command="{Binding RefreshModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,5"/>
                    
                    <Button Content="✅ Enable All" Command="{Binding EnableAllModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,5,0,5"/>
                    
                    <Button Content="❌ Disable All" Command="{Binding DisableAllModsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,5,0,5"/>
                    
                    <Button Content="📁 Open Mods Folder" Command="{Binding OpenModsFolderCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,5,0,0"/>
                    
                    <Separator Margin="0,15,0,10"/>
                    
                    <StackPanel Margin="5">
                        <TextBlock Text="📊 Statistics" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock>
                            <Run Text="Total Mods: "/>
                            <Run Text="{Binding TotalModsCount}" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Margin="0,5,0,0">
                            <Run Text="Enabled: "/>
                            <Run Text="{Binding EnabledModsCount}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Mod List -->
            <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Tabs -->
                    <TabControl Grid.Row="1" BorderThickness="0">
                        <!-- All Mods Tab -->
                        <TabItem Header="All Mods">
                            <ListView ItemsSource="{Binding AllMods}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}" 
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeDisplay}" Width="100"/>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusIndicator}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Maps Tab -->
                        <TabItem Header="🗺️ Maps">
                            <ListView ItemsSource="{Binding Maps}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="250"/>
                                        <GridViewColumn Header="Holes" DisplayMemberBinding="{Binding Meta.Holes}" Width="60"/>
                                        <GridViewColumn Header="Difficulty" DisplayMemberBinding="{Binding Meta.Difficulty}" Width="100"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Game Modes Tab -->
                        <TabItem Header="🎮 Game Modes">
                            <ListView ItemsSource="{Binding GameModes}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Characters Tab -->
                        <TabItem Header="👤 Characters">
                            <ListView ItemsSource="{Binding Characters}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                        
                        <!-- Items Tab -->
                        <TabItem Header="⚔️ Items">
                            <ListView ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedMod}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="✓" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="80"/>
                                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Mod Details Panel -->
                    <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                        <StackPanel DataContext="{Binding SelectedMod}">
                            <TextBlock Text="Mod Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,5,0,5"/>
                            <TextBlock Margin="0,5,0,0">
                                <Run Text="Author: "/><Run Text="{Binding Author}" FontWeight="SemiBold"/>
                                <Run Text=" • "/>
                                <Run Text="Version: "/><Run Text="{Binding Version}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#263238" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="v1.0.0" Foreground="#B0BEC5" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
